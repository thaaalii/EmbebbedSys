        <mxCell id="ss5m7s-RIth3CUoP5uVA-3" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="260" width="393" x="370" y="600" as="geometry" />
        </mxCell>
        <mxCell id="ss5m7s-RIth3CUoP5uVA-4" parent="1" style="text;whiteSpace=wrap;html=1;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="&lt;div align=&quot;justify&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;Para ambientes maiores, recomendamos uma implantação distribuída. A &lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;configuração de cluster de vários nós está disponível &lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;para o servidor Wazuh e para o indexador&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;Wazuh, fornecendo alta disponibilidade e balanceamento de carga.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="392" x="368" y="864" as="geometry" />
        </mxCell>
        <mxCell id="ss5m7s-RIth3CUoP5uVA-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=light-dark(#000000,#F4F4F4);fillColor=light-dark(#FFFFFF,#F4F4F4);" value="" vertex="1">
          <mxGeometry height="430" width="410" x="790" y="500" as="geometry" />
        </mxCell>
        <mxCell id="ss5m7s-RIth3CUoP5uVA-8" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=17;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;Sistemas Operacionais&lt;/span&gt;" vertex="1">
          <mxGeometry height="40" width="190" x="800" y="510" as="geometry" />
        </mxCell>
        <mxCell id="ss5m7s-RIth3CUoP5uVA-9" parent="1" style="text;whiteSpace=wrap;html=1;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="&lt;div align=&quot;justify&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;Os componentes centrais do Wazuh podem ser instalados em um sistema operacional Linux de 64 bits. Wazuh recomenda qualquer uma das seguintes versões de sistema operacional:&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="390" x="800" y="550" as="geometry" />
        </mxCell>
        <mxCell id="ss5m7s-RIth3CUoP5uVA-10" parent="1" style="text;whiteSpace=wrap;html=1;fontColor=light-dark(#FFFFFF,#000000);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="&lt;li&gt;&lt;p&gt;Amazon Linux 2, Amazon Linux 2023&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;CentOS Stream 10&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Red Hat Enterprise Linux 7, 8, 9, 10&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;Ubuntu 16.04, 18.04, 20.04, 22.04, 24.04&lt;/p&gt;&lt;/li&gt;" vertex="1">
          <mxGeometry height="130" width="310" x="840" y="590" as="geometry" />
        </mxCell>
        <mxCell id="ss5m7s-RIth3CUoP5uVA-13" parent="1" style="text;whiteSpace=wrap;fontColor=light-dark(#000000,#000000);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="O painel do Wazuh suporta os seguintes navegadores da Web:&#xa;&#xa; &#xa;&#xa;&#xa;&#xa;Outros navegadores baseados no Chromium também podem funcionar. Não há suporte para o Internet Explorer 11." vertex="1">
          <mxGeometry height="170" width="390" x="800" y="754" as="geometry" />
        </mxCell>
        <mxCell id="ss5m7s-RIth3CUoP5uVA-15" parent="1" style="text;whiteSpace=wrap;html=1;fontColor=light-dark(#000000,#000000);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="&lt;ul&gt;&lt;li&gt;Chrome 95 ou posterior&lt;/li&gt;&lt;li&gt;Firefox 93 ou posterior&lt;/li&gt;&lt;li&gt;Safari 13.7 ou posterior&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="85" width="190" x="800" y="772.5" as="geometry" />
        </mxCell>
        <mxCell id="ss5m7s-RIth3CUoP5uVA-17" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=17;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(0, 0, 0));&quot;&gt;Navegadores compatíveis&lt;/span&gt;" vertex="1">
          <mxGeometry height="40" width="210" x="800" y="714" as="geometry" />
        </mxCell>
        <mxCell id="ss5m7s-RIth3CUoP5uVA-19" parent="1" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=light-dark(#000000,#F4F4F4);fillColor=light-dark(#FFFFFF,#F4F4F4);" value="" vertex="1">
          <mxGeometry height="446" width="2200" x="364.5" y="1753" as="geometry" />
        </mxCell>
        <mxCell id="-5q7wsz17vjpn69_9i57-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#F4F4F4);strokeColor=light-dark(#000000,#CFCFCF);movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="" vertex="1">
          <mxGeometry height="370" width="1040" x="400" y="1800" as="geometry" />
        </mxCell>
        <mxCell id="ss5m7s-RIth3CUoP5uVA-20" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontColor=light-dark(#000000,#000000);fontSize=18;" value="&lt;div&gt;Legenda:&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="88" x="450" y="1770" as="geometry" />
        </mxCell>
        <mxCell id="ss5m7s-RIth3CUoP5uVA-27" parent="1" style="text;whiteSpace=wrap;fontColor=light-dark(#000000,#000000);fontStyle=0;html=1;textShadow=0;autosizeText=0;fontSize=12;movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;fontFamily=Helvetica;align=left;verticalAlign=top;" value="&lt;div style=&quot;line-height: 100%;&quot; align=&quot;justify&quot;&gt;&lt;font style=&quot;font-size: 13px; line-height: 100%; color: light-dark(rgb(51, 51, 255), rgb(51, 51, 255));&quot;&gt;&lt;b&gt;Daemon do Agente&lt;/b&gt;&lt;/font&gt;&lt;font style=&quot;font-size: 13px; line-height: 100%; color: light-dark(rgb(0, 0, 0), rgb(51, 51, 255));&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 100%;&quot; align=&quot;justify&quot;&gt;&lt;b&gt;Criptografia:&lt;/b&gt; Garante que todos os dados coletados (logs, eventos, alertas) sejam &lt;span data-path-to-node=&quot;4&quot; data-index-in-node=&quot;143&quot;&gt;cifrados&lt;/span&gt; (geralmente via AES) antes de serem enviados ao servidor Wazuh.&lt;/div&gt;&lt;div style=&quot;line-height: 100%;&quot; align=&quot;justify&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 100%;&quot; align=&quot;justify&quot;&gt;&lt;b&gt;Gerenciamento de Módulos:&amp;nbsp;&lt;/b&gt;Ele é responsável por iniciar, parar e monitorar todos os outros módulos. Atua como um &quot;maestro&quot;.&lt;/div&gt;&lt;div style=&quot;line-height: 100%;&quot; align=&quot;justify&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 100%;&quot; align=&quot;justify&quot;&gt;&lt;b&gt;Configuração Remota:&lt;/b&gt;&amp;nbsp;Ele permite que você altere as configurações do agente (o que ele deve monitorar diretamente pelo &lt;span data-path-to-node=&quot;8&quot; data-index-in-node=&quot;168&quot;&gt;Servidor Central&lt;/span&gt;. O daemon recebe essas instruções e as aplica localmente.&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 100%;&quot; align=&quot;justify&quot;&gt;&lt;b&gt;Autenticação de servidor:&lt;/b&gt;&amp;nbsp;Para evitar que um agente envie dados para um servidor falso (ataque de &lt;i data-path-to-node=&quot;10&quot; data-index-in-node=&quot;72&quot;&gt;man-in-the-middle&lt;/i&gt;), o daemon utiliza certificados e chaves de autenticação. Ele verifica a identidade do servidor Wazuh antes de estabelecer a conexão, garantindo que o canal de comunicação seja confiável para ambos os lados.&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="480" x="930" y="1810" as="geometry" />
        </mxCell>
        <mxCell id="ss5m7s-RIth3CUoP5uVA-26" parent="1" style="text;whiteSpace=wrap;fontColor=light-dark(#000000,#000000);fontStyle=0;html=1;textShadow=0;autosizeText=0;fontSize=12;movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;" value="&lt;div style=&quot;line-height: 100%;&quot; align=&quot;justify&quot;&gt;&lt;font style=&quot;font-size: 13px; line-height: 100%; color: light-dark(rgb(51, 51, 255), rgb(51, 51, 255));&quot;&gt;&lt;b&gt;Módulos do Agente (Agent Modules)&lt;/b&gt;&lt;/font&gt;&lt;font style=&quot;font-size: 13px; color: light-dark(rgb(0, 0, 0), rgb(51, 51, 255)); line-height: 100%;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;br&gt;&lt;div&gt;&lt;b&gt;Resposta Ativa:&lt;/b&gt; Executa ações automáticas quando uma ameaça é detectada (ex: bloquear um IP no firewall).&lt;/div&gt;&lt;br&gt;&lt;b&gt;Execução de comandos:&lt;/b&gt; Permite que o servidor envie comandos para serem executados no endpoint.&lt;br&gt;&lt;br&gt;&lt;b&gt;Avaliação de Configuração:&lt;/b&gt; Verifica se as configurações do sistema estão seguras e seguem boas práticas (como os padrões CIS).&lt;br&gt;&lt;br&gt;&lt;b&gt;Segurança de Contêiners:&lt;/b&gt; Monitora a segurança de ambientes Docker ou Kubernetes.&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 100%;&quot; align=&quot;justify&quot;&gt;&lt;b&gt;Segurança em nuvens:&lt;/b&gt; Integração para monitorar instâncias em nuvens como AWS, Azure e GCP.&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;line-height: 100%;&quot; align=&quot;justify&quot;&gt;&lt;b&gt;Monitoramente de integridade de Arquivos&lt;/b&gt;: Detecta se arquivos importantes foram criados, modificados ou deletados (essencial contra Rootkits).&lt;br&gt;&lt;br&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp; Coletor de Logs:&lt;/b&gt; &quot;Lê&quot; os logs do sistema operacional e de aplicativos para enviá-los ao servidor.&lt;br&gt;&lt;br&gt;&lt;b&gt;Detecção de Malware:&lt;/b&gt; Procura por assinaturas de vírus, rootkits e anomalias no sistema.&lt;br&gt;&lt;br&gt;&lt;b&gt;Inventário de Sistema:&lt;/b&gt; Coleta dados de hardware, programas instalados e interfaces de rede.&lt;/div&gt;" vertex="1">
          <mxGeometry height="360" width="480" x="430" y="1805" as="geometry" />
        </mxCell>
        <mxCell id="-5q7wsz17vjpn69_9i57-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#F4F4F4);strokeColor=light-dark(#000000,#CFCFCF);movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;" value="" vertex="1">
          <mxGeometry height="370" width="530" x="1450" y="1800" as="geometry" />
        </mxCell>
        <mxCell id="lILieu8HvBD8JmlwGWVS-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontFamily=Helvetica;fontSize=12;fontColor=light-dark(#000000,#000000);fontStyle=0;movable=0;resizable=0;rotatable=0;deletable=0;editable=0;locked=1;connectable=0;" value="&lt;div&gt;&lt;b style=&quot;color: light-dark(rgb(0, 0, 0), rgb(51, 51, 255));&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), transparent);&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(51, 51, 255));&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(102, 102, 255));&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;&lt;span style=&quot;color: rgb(51, 51, 255);&quot;&gt;W&lt;/span&gt;&lt;span style=&quot;color: rgb(51, 51, 255);&quot;&gt;&lt;span style=&quot;color: rgb(51, 51, 255);&quot;&gt;azuh Server&amp;nbsp;&lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;É o núcleo onde os dados são processados e as decisões de segurança são tomadas.&lt;br&gt;&lt;b&gt;&lt;br&gt;Serviços de Agente:&lt;/b&gt; Gerenciam a conexão, o registro e a comunicação segura com os endpoints.&lt;br&gt;&lt;br&gt;&lt;b&gt;Ouvinte Syslog: &lt;/b&gt;Recebe logs de dispositivos de rede (firewalls, switches) que não possuem agentes instalados.&lt;br&gt;&lt;br&gt;&lt;b&gt;Mecanismo de Análise:&lt;/b&gt; Onde ocorre a decodificação dos logs, comparação com regras e enriquecimento dos dados para identificar ameaças.&lt;br&gt;&lt;br&gt;&lt;div&gt;&lt;b&gt;Módulos de Inteligência (Azul): &lt;/b&gt;Funções avançadas que cruzam dados com bancos de ameaças externos, detectam softwares vulneráveis e verificam a conformidade com normas (como a LGPD).&lt;/div&gt;&lt;div&gt;&lt;h3 data-path-to-node=&quot;8&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(51, 51, 255), rgb(51, 51, 255));&quot;&gt;&lt;font style=&quot;font-size: 13px;&quot;&gt;Filebeat&lt;/font&gt;&lt;/span&gt;&lt;/h3&gt;&lt;p data-path-to-node=&quot;9,0,0&quot;&gt;&lt;b data-path-to-node=&quot;9,0,0&quot; data-index-in-node=&quot;0&quot;&gt;Função:&lt;/b&gt; Atua como um mensageiro seguro. Ele lê os &lt;b data-path-to-node=&quot;9,0,0&quot; data-index-in-node=&quot;50&quot;&gt;Alertas de Segurança&lt;/b&gt; e &lt;b data-path-to-node=&quot;9,0,0&quot; data-index-in-node=&quot;73&quot;&gt;Eventos Brutos&lt;/b&gt; gerados pelo servidor e os envia em tempo real para o Indexador.&lt;/p&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="330" width="466" x="1488" y="1820" as="geometry" />
        </mxCell>
        <mxCell id="lILieu8HvBD8JmlwGWVS-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=light-dark(#FFFFFF,#F4F4F4);strokeColor=light-dark(#000000,#CFCFCF);movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;" value="" vertex="1">
          <mxGeometry height="370" width="530" x="2000" y="1800" as="geometry" />
        </mxCell>
        <mxCell id="lILieu8HvBD8JmlwGWVS-3" parent="1" style="text;whiteSpace=wrap;fontStyle=0;fontColor=light-dark(#000000,#000000);html=1;" value="&lt;div style=&quot;line-height: 100%;&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(51, 51, 255), rgb(51, 51, 255));&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(51, 51, 255), rgb(51, 51, 255));&quot;&gt;&lt;b&gt;Wazuh Indexer (A Memória)&lt;/b&gt;&lt;br&gt;&lt;/span&gt;&lt;/span&gt;&lt;br&gt;Um motor de busca e análise de texto completo, altamente escalável.&lt;br&gt;&lt;br&gt;&lt;div align=&quot;justify&quot;&gt;&lt;b&gt;Armazenamento de Longo Prazo: &lt;/b&gt;Guarda o histórico de eventos para investigações futuras e auditorias.&lt;br&gt;&lt;/div&gt;&lt;br&gt;&lt;b&gt;Dados de Inventário e Monitoramento: &lt;/b&gt;Organiza as informações coletadas sobre o estado das máquinas e a saúde dos agentes.&lt;br&gt;&lt;br&gt;&lt;b&gt;Análise de Dados: &lt;/b&gt;Permite que o sistema realize buscas complexas em milissegundos.&lt;/div&gt;" vertex="1">
          <mxGeometry height="168" width="470" x="2030" y="1822" as="geometry" />
        </mxCell>
        <mxCell id="lILieu8HvBD8JmlwGWVS-4" parent="1" style="text;whiteSpace=wrap;fontColor=light-dark(#000000,#000000);fontStyle=0;fontFamily=Helvetica;fontSize=12;align=left;verticalAlign=top;" value="Wazuh Dashboard (A Interface)&#xa;&#xa;A interface visual para mineração de dados, visualização e gerenciamento.&#xa;&#xa;Visualizações e Painéis: Gráficos interativos que mostram o status da segurança em tempo real.&#xa;&#xa;Linguagem de Consulta: Permite que o analista faça filtros específicos para investigar incidentes." vertex="1">
          <mxGeometry height="150" width="470" x="2030" y="1990" as="geometry" />
        </mxCell>
        <mxCell id="R6a4QqXc1kNwlkj17gh_-1" parent="1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;fillColor=default;" value="&#xa;" vertex="1">
